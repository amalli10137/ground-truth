{
  "name": "ground-truth",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --exclude '**/*.integration.test.*'",
    "test:integration": "vitest run --testTimeout 240000 src/worker/bridge.integration.test.ts",
    "data": "python3 -m datagen.build",
    "data:test": "python3 -m pytest datagen/tests -q",
    "test:e2e": "node scripts/e2e.mjs"
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.1.6",
    "@fontsource/ibm-plex-mono": "^5.1.0",
    "@fontsource/space-grotesk": "^5.1.0",
    "codemirror": "^6.0.1",
    "katex": "^0.16.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uplot": "^1.6.31"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/node": "^26.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.1",
    "pyodide": "^0.26.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
